---
permalink: /sitemap.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="UTF-8"?>
<!--
  ROOT sitemap for munderdiffl.in. Owned + auto-generated by the Eleventy blog
  build (agreed with Kevin, Option A): includes the marketing homepage plus every
  blog page so posts never orphan. Eleventy emits it under docs/blog/, then the
  postbuild step (scripts/postbuild.mjs) moves it to docs/sitemap.xml — which is
  where robots.txt points (https://munderdiffl.in/sitemap.xml).
  Post <lastmod> uses real publish/update dates, not build time.
-->
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc>{{ site.origin }}/</loc>
    <lastmod>{{ build.date }}</lastmod>
    <changefreq>weekly</changefreq>
    <priority>1.0</priority>
  </url>
  <url><loc>{{ site.baseUrl }}</loc><changefreq>daily</changefreq><priority>0.9</priority></url>
  <url><loc>{{ site.origin }}{{ '/topics/' | u }}</loc><changefreq>weekly</changefreq><priority>0.6</priority></url>
  <url><loc>{{ site.origin }}{{ '/about/' | u }}</loc><changefreq>monthly</changefreq><priority>0.4</priority></url>
  {%- for p in collections.posts %}
  <url>
    <loc>{{ site.origin }}{{ p.url | u }}</loc>
    <lastmod>{{ (p.data.updated or p.date) | htmlDate }}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.8</priority>
  </url>
  {%- endfor %}
  {%- for c in collections.categories %}
  <url><loc>{{ site.origin }}{{ ('/topics/' + c.slug + '/') | u }}</loc><changefreq>weekly</changefreq><priority>0.5</priority></url>
  {%- endfor %}
  {%- for t in collections.tagList %}
  <url><loc>{{ site.origin }}{{ ('/tags/' + t.slug + '/') | u }}</loc><changefreq>weekly</changefreq><priority>0.3</priority></url>
  {%- endfor %}
</urlset>
